{
  "name": "@philiprehberger/abort-kit",
  "version": "0.1.3",
  "description": "AbortController utilities — timeout, race, linked signals",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "abort",
    "abort-controller",
    "abort-signal",
    "timeout",
    "cancel",
    "cleanup"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-abort-kit.git"
  },
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-abort-kit/issues"
  },
  "homepage": "https://github.com/philiprehberger/ts-abort-kit#readme",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.2",
    "@types/node": "^22.0.0"
  }
}
